<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- 해당 파일에 모든 쿼리문을 작성 -->
<!-- namespace에는 xml파일과 연결할 Mapper interface 파일명을 패키지를 포함하여 적어주세요 -->
<mapper namespace="com.green.farm_animals_shop.user.mapper.QuestionMapper">

    <!--검색 버튼 클릭 시 게시글 목록 조회 -->
    <select id="getQuestionList" resultType="QuestionDTO">
        SELECT
        q.QUESTION_NUM AS questionNum,
        q.TITLE,
        q.USER_ID AS userId,
        q.REG_DATE AS regDate,
        q.READ_CNT AS readCnt,
        i.ITEM_NAME AS itemName,
        i.IMAGE_PATH AS imagePath
        FROM questions q
        LEFT JOIN item_info i ON q.ITEM_CODE = i.ITEM_CODE
        <where>
            <!-- userId가 있을 경우에만 필터 -->
            <if test="userId != null and userId != ''">
                q.USER_ID = #{userId}
            </if>
            <if test="searchValue != null and searchValue != ''">
                <choose>
                    <when test="searchKeyword == 'title'">
                        AND q.TITLE LIKE CONCAT('%', #{searchValue}, '%')
                    </when>
                    <when test="searchKeyword == 'userId'">
                        AND q.USER_ID LIKE CONCAT('%', #{searchValue}, '%')
                    </when>
                    <!-- 필요한 경우 다른 필드도 추가 -->
                </choose>
            </if>
        </where>
        ORDER BY q.QUESTION_NUM DESC
        LIMIT #{offset}, #{size}
    </select>



    <select id="getQuestionListCount" resultType="int">
        SELECT COUNT(*) <!-- COUNT(*)는 전체 게시글 수 -->
        FROM questions
        <if test="searchValue != null and searchValue != ''">
            ${searchKeyword} LIKE CONCAT('%', #{searchValue}, '%') <!-- 검색어가 있을 경우 -->
        </if>
    </select>

    <!--Q&A 게시글 등록 쿼리(첨부파일보류)-->
    <insert id="insertQuestion">
        INSERT INTO questions (
            TITLE
            , USER_ID
            , CONTENT
            , ITEM_CODE
        ) VALUES (
            #{title}
            , #{userId}
            , #{content}
            , #{itemCode}
        )
    </insert>

    <!--Q&A 게시글 상세 조회-->
    <select id="getQuestion" resultType="QuestionDTO">
        SELECT *
        FROM questions
        WHERE QUESTION_NUM = #{questionNum}
    </select>

    <!--Q&A 게시글 삭제-->
    <delete id="deleteQuestion">
        DELETE FROM questions
        WHERE QUESTION_NUM = #{questionNum}
    </delete>

    <!--Q&A 게시글 수정-->
    <update id="updateQuestion">
        UPDATE questions
        SET
            TITLE = #{title}
            , CONTENT = #{content}
    </update>

    <!--Q&A 게시글 조회수 증가-->
    <update id="updateReadCnt">
        UPDATE questions
        SET
        READ_CNT = READ_CNT + 1
        WHERE QUESTION_NUM = #{questionNum}
    </update>

    <!--답글 목록 조회-->
    <select id="getAnswerList" resultType="AnswerDTO">
        SELECT *
        FROM QUESTION_ANSWER
        WHERE QUESTION_NUM = #{questionNum}
        ORDER BY REG_DATE DESC
    </select>

    <!--답글 등록-->
    <insert id="insertAnswer">
        INSERT INTO QUESTION_ANSWER (
            CONTENT
            , WRITER
            , QUESTION_NUM
        ) VALUES (
            #{content}
            , #{writer}
            , #{questionNum}
        )
    </insert>

    <!--답글 삭제-->
    <delete id="deleteAnswer">
        DELETE FROM QUESTION_ANSWER
        WHERE ANSWER_NUM = #{answerNum}
    </delete>

</mapper>































